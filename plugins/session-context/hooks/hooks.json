{
  "description": "Session context - injects daily work context on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-context.sh",
            "timeout": 15,
            "statusMessage": "Loading work context..."
          }
        ]
      }
    ]
  }
}
